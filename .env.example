# 卡号和密码
SCUT_USERNAME="your_username" # 注：此处为一卡通界面的"卡号"
SCUT_PASSWORD="your_password" # 注：此处为查询密码

# LiteLLM 配置 - 用于识别验证码
# 模型名称, 例如: "gemini/gemini-2.5-pro", 详见 https://docs.litellm.ai/docs/providers
LLM_MODEL="gemini/gemini-2.5-pro"
LLM_API_KEY="your_llm_api_key_here"
# 如果使用自定义的LLM服务，请取消下面的注释并设置API Base URL
# LLM_API_BASE="https://your-custom-llm-service.com/v1"

#--- 告警配置 ---
#低电量告警阈值（单位：度）。
# 含义：当“当前剩余电量（度）”小于该阈值时，触发“低电量”告警。
# 同时程序会根据近 7 日平均用电量预测“预计用尽日期”，若 3 天内可能用尽也会触发告警。
# 建议：宿舍/办公室一般设为 10~30，默认 20。
ELECTRICITY_ALERT_THRESHOLD=20

# --- 邮件通知配置 (可选) ---
# 说明：仅当以下所有 EMAIL_* 均已配置时，程序才会通过邮箱发送告警；否则自动回退为日志通知。
# EMAIL_SMTP_SERVER：SMTP 服务器地址
# - QQ 邮箱：smtp.qq.com
# - 163 邮箱：smtp.163.com
# - Gmail：smtp.gmail.com（通常需“应用专用密码”或 OAuth2）
# - 企业/学校邮箱：请咨询管理员或查阅提供商文档
EMAIL_SMTP_SERVER="smtp.qq.com"

# EMAIL_SMTP_PORT：SMTP 端口
# - 587：使用 STARTTLS（当前代码默认支持）
# - 465：使用 SSL（如需使用，请告知，我可将代码兼容 SMTP_SSL）
EMAIL_SMTP_PORT=587

# EMAIL_SMTP_USER：发件人邮箱账号（完整邮箱地址）
# - 例如 QQ 邮箱：你的QQ号@qq.com
EMAIL_SMTP_USER="123456@qq.com"

# EMAIL_SMTP_PASSWORD：发件人邮箱的“客户端授权码/应用专用密码”（不是登录密码）
# - QQ 邮箱：设置 -> 账户 -> 开启“POP3/SMTP服务”，系统会生成“授权码”
# - 163/Gmail/Outlook/企业邮箱：去安全设置创建“应用专用密码”或使用 OAuth2
EMAIL_SMTP_PASSWORD="your_email_app_password_or_token"

# 收件人邮箱地址（支持多个）
# 方式一：使用 EMAIL_RECIPIENTS，多个地址用逗号/分号/空格/换行分隔
# EMAIL_RECIPIENTS="a@example.com, b@example.com; c@example.com d@example.com"
# 方式二：保留兼容单个的 EMAIL_RECIPIENT
EMAIL_RECIPIENT="recipient_email@example.com"

# 非网络层识别重试次数（当一次识别得到的候选全部失败时，整轮重试次数）
# 建议取值：1-5，默认1
LLM_RECOGNITION_RETRIES=1